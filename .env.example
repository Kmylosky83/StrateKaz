# =============================================================================
# STRATEKAZ - Variables de Entorno
# =============================================================================
# Copiar este archivo a .env y configurar los valores
# NUNCA commitear el archivo .env al repositorio
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-min-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Base de Datos PostgreSQL
# -----------------------------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=stratekaz
DB_USER=stratekaz
DB_PASSWORD=stratekaz_dev_2024
DB_HOST=localhost
DB_PORT=5432

# Para Docker usar:
# DB_HOST=db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# Para Docker usar:
# REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Para Docker usar:
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# -----------------------------------------------------------------------------
# Email (Desarrollo)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Email (Producción)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Sentry (Producción)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://your-sentry-dsn
# SENTRY_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Frontend URL
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3010

# -----------------------------------------------------------------------------
# Multi-tenant
# -----------------------------------------------------------------------------
# Dominio base para subdominios de tenants
TENANT_BASE_DOMAIN=localhost

# -----------------------------------------------------------------------------
# pgAdmin (Docker)
# -----------------------------------------------------------------------------
PGADMIN_PASSWORD=admin123

# -----------------------------------------------------------------------------
# Storage (Producción)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
