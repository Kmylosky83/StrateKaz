# ═══════════════════════════════════════════════════
# CONFIGURACIÓN DE PRODUCCIÓN
# Grasas y Huesos del Norte S.A.S
# ═══════════════════════════════════════════════════
# IMPORTANTE: Copiar este archivo como .env.production y completar valores

# ═══════════════════════════════════════════════════
# APLICACIÓN
# ═══════════════════════════════════════════════════
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-to-random-string-minimum-50-chars
DJANGO_SETTINGS_MODULE=config.settings

# ═══════════════════════════════════════════════════
# DOMINIO Y HOSTS
# ═══════════════════════════════════════════════════
DOMAIN=example.com
ALLOWED_HOSTS=example.com,www.example.com,api.example.com
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# ═══════════════════════════════════════════════════
# BASE DE DATOS MYSQL
# ═══════════════════════════════════════════════════
MYSQL_DATABASE=grasas_huesos_prod
MYSQL_ROOT_PASSWORD=change-this-root-password-very-secure
MYSQL_USER=grasas_user_prod
MYSQL_PASSWORD=change-this-user-password-very-secure

# Configuración Django DB
DATABASE_NAME=grasas_huesos_prod
DATABASE_USER=grasas_user_prod
DATABASE_PASSWORD=change-this-user-password-very-secure
DATABASE_HOST=db
DATABASE_PORT=3306

# ═══════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════
REDIS_PASSWORD=change-this-redis-password-very-secure
REDIS_URL=redis://:change-this-redis-password-very-secure@redis:6379/2
CELERY_BROKER_URL=redis://:change-this-redis-password-very-secure@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-this-redis-password-very-secure@redis:6379/1

# ═══════════════════════════════════════════════════
# SEGURIDAD SSL/TLS
# ═══════════════════════════════════════════════════
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ═══════════════════════════════════════════════════
# EMAIL / SMTP
# ═══════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=SGI Grasas y Huesos <noreply@example.com>

# ═══════════════════════════════════════════════════
# SENTRY - MONITOREO DE ERRORES
# ═══════════════════════════════════════════════════
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ═══════════════════════════════════════════════════
# FRONTEND
# ═══════════════════════════════════════════════════
VITE_API_URL=https://api.example.com/api
VITE_APP_NAME=Grasas y Huesos del Norte

# ═══════════════════════════════════════════════════
# FLOWER - MONITOREO CELERY
# ═══════════════════════════════════════════════════
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-flower-password

# ═══════════════════════════════════════════════════
# BACKUPS
# ═══════════════════════════════════════════════════
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *
# Programación cron: minuto hora día mes día-semana
# 0 2 * * * = Todos los días a las 2:00 AM

# ═══════════════════════════════════════════════════
# JWT TOKENS
# ═══════════════════════════════════════════════════
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ═══════════════════════════════════════════════════
# CONFIGURACIÓN DE NEGOCIO
# ═══════════════════════════════════════════════════
PRECIO_COMPRA_ECONORTE=3500
PRECIO_REFERENCIA_COMISION=3000
COMISION_FIJA_POR_KILO=100

# ═══════════════════════════════════════════════════
# BUILD INFO (Generado automáticamente)
# ═══════════════════════════════════════════════════
BUILD_DATE=2025-01-01T00:00:00Z
VCS_REF=main

# ═══════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════
DJANGO_LOG_LEVEL=INFO
DB_LOG_LEVEL=WARNING
