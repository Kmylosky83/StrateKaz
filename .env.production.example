# ═══════════════════════════════════════════════════
# CONFIGURACIÓN DE PRODUCCIÓN
# StrateKaz
# ═══════════════════════════════════════════════════
# IMPORTANTE: Copiar este archivo como .env.production y completar valores

# ═══════════════════════════════════════════════════
# APLICACIÓN
# ═══════════════════════════════════════════════════
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-to-random-string-minimum-50-chars
DJANGO_SETTINGS_MODULE=config.settings.production

# ═══════════════════════════════════════════════════
# DOMINIO Y HOSTS
# ═══════════════════════════════════════════════════
DOMAIN=stratekaz.com
ALLOWED_HOSTS=stratekaz.com,app.stratekaz.com,*.stratekaz.com
CORS_ALLOWED_ORIGINS=https://stratekaz.com,https://app.stratekaz.com
CSRF_TRUSTED_ORIGINS=https://stratekaz.com,https://app.stratekaz.com

# ═══════════════════════════════════════════════════
# BASE DE DATOS POSTGRESQL
# ═══════════════════════════════════════════════════
DB_ENGINE=django_tenants.postgresql_backend
DB_NAME=stratekaz
DB_USER=stratekaz_user
DB_PASSWORD=change-this-password-very-secure
DB_HOST=localhost
DB_PORT=5432

# ═══════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════
REDIS_PASSWORD=change-this-redis-password-very-secure
REDIS_URL=redis://:change-this-redis-password-very-secure@localhost:6379/0
CELERY_BROKER_URL=redis://:change-this-redis-password-very-secure@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:change-this-redis-password-very-secure@localhost:6379/1

# ═══════════════════════════════════════════════════
# SEGURIDAD SSL/TLS
# ═══════════════════════════════════════════════════
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ═══════════════════════════════════════════════════
# EMAIL / SMTP
# ═══════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@stratekaz.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=SGI StrateKaz <noreply@stratekaz.com>

# ═══════════════════════════════════════════════════
# SENTRY - MONITOREO DE ERRORES
# ═══════════════════════════════════════════════════
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ═══════════════════════════════════════════════════
# FRONTEND
# ═══════════════════════════════════════════════════
VITE_API_URL=https://app.stratekaz.com/api
VITE_APP_NAME=StrateKaz

# ═══════════════════════════════════════════════════
# FLOWER - MONITOREO CELERY
# ═══════════════════════════════════════════════════
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-flower-password

# ═══════════════════════════════════════════════════
# BACKUPS
# ═══════════════════════════════════════════════════
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *

# ═══════════════════════════════════════════════════
# JWT TOKENS
# ═══════════════════════════════════════════════════
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ═══════════════════════════════════════════════════
# MULTI-TENANT
# ═══════════════════════════════════════════════════
TENANT_BASE_DOMAIN=stratekaz.com

# ═══════════════════════════════════════════════════
# BUILD INFO (Generado automaticamente)
# ═══════════════════════════════════════════════════
BUILD_DATE=2025-01-01T00:00:00Z
VCS_REF=main

# ═══════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════
DJANGO_LOG_LEVEL=INFO
DB_LOG_LEVEL=WARNING
