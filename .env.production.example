# ===================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Grasas y Huesos del Norte S.A.S
# ===================================================================
#
# IMPORTANTE:
# 1. Copiar este archivo a .env.production
# 2. Reemplazar TODOS los valores con credenciales seguras
# 3. NUNCA commitear .env.production al repositorio
# 4. Usar secretos fuertes generados aleatoriamente
#
# GENERACIÓN DE SECRETOS:
#   Python: python -c "import secrets; print(secrets.token_urlsafe(50))"
#   OpenSSL: openssl rand -base64 32
# ===================================================================

# --- Build Information ---
BUILD_DATE=2024-01-01T00:00:00Z
VCS_REF=main

# --- Database Configuration ---
MYSQL_DATABASE=grasas_huesos_prod
MYSQL_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD_STRONG_AND_RANDOM
MYSQL_USER=grasas_user_prod
MYSQL_PASSWORD=CHANGE_THIS_USER_PASSWORD_STRONG_AND_RANDOM
MYSQL_ROOT_HOST=%

# --- Django Backend Configuration ---
DEBUG=False
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING_AT_LEAST_50_CHARACTERS_LONG

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# Database
DATABASE_ENGINE=django.db.backends.mysql
DATABASE_NAME=grasas_huesos_prod
DATABASE_USER=grasas_user_prod
DATABASE_PASSWORD=CHANGE_THIS_USER_PASSWORD_STRONG_AND_RANDOM
DATABASE_HOST=db
DATABASE_PORT=3306

# CORS Origins (separados por coma)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
X_FRAME_OPTIONS=DENY

# --- Frontend Configuration ---
VITE_API_URL=https://api.yourdomain.com/api
VITE_APP_NAME=Grasas y Huesos del Norte

# --- Ports (Internal) ---
BACKEND_PORT=8000
FRONTEND_PORT=80
MYSQL_PORT=3306

# --- Data Paths ---
DATA_PATH=/var/lib/grasas-huesos

# --- Email Configuration (Opcional) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=CHANGE_THIS_EMAIL_PASSWORD
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# --- JWT Configuration ---
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# --- Monitoring (Opcional) ---
# SENTRY_DSN=https://your-sentry-dsn
# SENTRY_ENVIRONMENT=production

# --- Backup Configuration ---
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# --- Redis Configuration ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/2

# --- Celery Configuration ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
