# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE PRODUCCIÓN PARA cPanel
# Sistema de Gestión Integral - StrateKaz
# ═══════════════════════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copia este archivo como .env en el directorio backend/
# 2. Reemplaza TODOS los valores con los de tu entorno de producción
# 3. NUNCA subas este archivo a Git con valores reales
# 4. Guarda una copia segura de este archivo (fuera del servidor)
#
# CONFIGURACIÓN EN cPanel:
# - Puedes configurar variables de entorno en "Setup Python App" > "Environment variables"
# - O usar este archivo .env (python-decouple lo cargará automáticamente)
#
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# DJANGO CORE
# ═══════════════════════════════════════════════════════════════════════════

# SECRET_KEY: CRÍTICO - Genera una nueva con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CAMBIAR_ESTO_POR_UNA_CLAVE_SECRETA_REAL_GENERADA_ALEATORIAMENTE_MINIMO_50_CARACTERES

# DEBUG: SIEMPRE False en producción
DEBUG=False

# ALLOWED_HOSTS: Dominios permitidos (separados por comas, sin espacios)
# Ejemplo: grasas.stratekaz.com,www.grasas.stratekaz.com
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# ═══════════════════════════════════════════════════════════════════════════
# BASE DE DATOS MySQL/MariaDB
# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANTE: En cPanel, obtén estos valores desde:
# - MySQL Databases > Current Databases
# - Remote MySQL (habilitar si es necesario)

# Nombre de la base de datos (en cPanel suele ser: usuario_nombredb)
DB_NAME=usuario_grasashuesos

# Usuario de MySQL (en cPanel suele ser: usuario_dbuser)
DB_USER=usuario_dbuser

# Contraseña del usuario de MySQL
DB_PASSWORD=CAMBIAR_POR_PASSWORD_REAL_DE_MYSQL

# Host de MySQL (usualmente 'localhost' en cPanel compartido)
DB_HOST=localhost

# Puerto de MySQL (por defecto 3306)
DB_PORT=3306

# ═══════════════════════════════════════════════════════════════════════════
# MODO cPanel
# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANTE: SIEMPRE True en cPanel (usa cache de BD en lugar de Redis)
USE_CPANEL=True

# ═══════════════════════════════════════════════════════════════════════════
# SEGURIDAD - CSRF & CORS
# ═══════════════════════════════════════════════════════════════════════════

# CSRF_TRUSTED_ORIGINS: URLs confiables para CSRF (incluir https://)
# Ejemplo: https://grasas.stratekaz.com,https://www.grasas.stratekaz.com
CSRF_TRUSTED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# CORS_ALLOWED_ORIGINS: Orígenes permitidos para CORS
# En producción, especifica solo los dominios necesarios
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ═══════════════════════════════════════════════════════════════════════════
# JWT - AUTENTICACIÓN
# ═══════════════════════════════════════════════════════════════════════════

# Duración del token de acceso (en minutos) - Default: 60
JWT_ACCESS_TOKEN_LIFETIME=60

# Duración del token de refresh (en minutos) - Default: 1440 (24 horas)
JWT_REFRESH_TOKEN_LIFETIME=1440

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL - SMTP
# ═══════════════════════════════════════════════════════════════════════════
# Configuración para envío de emails (notificaciones, recuperación de contraseña, etc.)

# Host SMTP (en cPanel puedes usar localhost o un servidor externo)
EMAIL_HOST=smtp.gmail.com

# Puerto SMTP (587 para TLS, 465 para SSL)
EMAIL_PORT=587

# Usar TLS
EMAIL_USE_TLS=True

# Usuario del email (dirección completa)
EMAIL_HOST_USER=noreply@tudominio.com

# Contraseña del email o App Password
EMAIL_HOST_PASSWORD=CAMBIAR_POR_PASSWORD_EMAIL

# Email por defecto para envíos
DEFAULT_FROM_EMAIL=noreply@tudominio.com

# ═══════════════════════════════════════════════════════════════════════════
# SENTRY - ERROR TRACKING (OPCIONAL)
# ═══════════════════════════════════════════════════════════════════════════
# Sentry captura errores en producción y envía notificaciones
# Regístrate en sentry.io y crea un proyecto Django

# DSN de Sentry (dejar vacío para deshabilitar)
SENTRY_DSN=

# Entorno (production, staging, etc.)
SENTRY_ENVIRONMENT=production

# Tasa de muestreo de traces (0.0 a 1.0) - 0.1 = 10%
SENTRY_TRACES_SAMPLE_RATE=0.1

# Tasa de muestreo de perfiles (0.0 a 1.0) - 0.1 = 10%
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE NEGOCIO - Grasas y Huesos del Norte
# ═══════════════════════════════════════════════════════════════════════════

# Precio de compra de Econorte (en pesos colombianos)
PRECIO_COMPRA_ECONORTE=3500

# Precio de referencia para comisión
PRECIO_REFERENCIA_COMISION=3000

# Comisión fija por kilo
COMISION_FIJA_POR_KILO=100

# ═══════════════════════════════════════════════════════════════════════════
# LOGGING - NIVELES DE LOG
# ═══════════════════════════════════════════════════════════════════════════

# Nivel de log para Django (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# Nivel de log para queries de base de datos
DB_LOG_LEVEL=WARNING

# ═══════════════════════════════════════════════════════════════════════════
# CELERY - TAREAS ASÍNCRONAS (MODO EAGER EN cPanel)
# ═══════════════════════════════════════════════════════════════════════════
# En cPanel, Celery ejecuta tareas de forma síncrona (EAGER mode)
# NO necesitas configurar Redis ni workers

# NOTA: Estas variables se ignoran en modo cPanel (USE_CPANEL=True)
# Se incluyen por compatibilidad si migras a VPS más adelante
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ═══════════════════════════════════════════════════════════════════════════
# REDIS - CACHE (NO DISPONIBLE EN cPanel COMPARTIDO)
# ═══════════════════════════════════════════════════════════════════════════
# En cPanel se usa Django Database Cache en lugar de Redis
# Esta variable se ignora cuando USE_CPANEL=True
REDIS_URL=

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN ADICIONAL
# ═══════════════════════════════════════════════════════════════════════════

# Zona horaria (Colombia)
TZ=America/Bogota

# Lenguaje
LANGUAGE_CODE=es-co

# ═══════════════════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES PARA cPanel
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. BACKUP DE ESTE ARCHIVO:
#    - Guarda una copia de este archivo en un lugar seguro
#    - NO lo incluyas en Git
#    - Usa un gestor de contraseñas para las credenciales
#
# 2. CONFIGURACIÓN DE VARIABLES EN cPanel:
#    Método 1: Usar este archivo .env (recomendado para múltiples variables)
#    Método 2: Configurar en "Setup Python App" > "Environment variables"
#              (útil para variables sensibles o para sobrescribir valores)
#
# 3. SEGURIDAD:
#    - Cambia TODAS las contraseñas por defecto
#    - Genera una SECRET_KEY única y segura
#    - Asegúrate de que DEBUG=False en producción
#    - Configura ALLOWED_HOSTS con tu dominio real
#
# 4. VALIDACIÓN:
#    Después de configurar, ejecuta:
#    python manage.py check --deploy
#
#    Esto mostrará advertencias de seguridad que debes resolver
#
# 5. TESTING:
#    Prueba la conexión a BD antes de desplegar:
#    python -c "import django; django.setup(); from django.db import connection; connection.ensure_connection(); print('✓ Conexión exitosa')"
#
# ═══════════════════════════════════════════════════════════════════════════
