# ═══════════════════════════════════════════════════
# DJANGO SETTINGS
# ═══════════════════════════════════════════════════
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ═══════════════════════════════════════════════════
# DATABASE CONFIGURATION (MySQL)
# ═══════════════════════════════════════════════════
DB_NAME=grasas_huesos_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# ═══════════════════════════════════════════════════
# JWT CONFIGURATION
# ═══════════════════════════════════════════════════
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ═══════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════
# EMAIL CONFIGURATION (Opcional para MVP)
# ═══════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@grasasyhuesos.com

# ═══════════════════════════════════════════════════
# PRECIOS Y CONFIGURACIONES DE NEGOCIO
# Configurados por el Gerente en la aplicación
# ═══════════════════════════════════════════════════
PRECIO_COMPRA_ECONORTE=3500
PRECIO_REFERENCIA_COMISION=3000
COMISION_FIJA_POR_KILO=100
