# ═══════════════════════════════════════════════════
# DJANGO SETTINGS
# ═══════════════════════════════════════════════════
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ═══════════════════════════════════════════════════
# DATABASE CONFIGURATION (MySQL)
# ═══════════════════════════════════════════════════
DB_NAME=grasas_huesos_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# ═══════════════════════════════════════════════════
# JWT CONFIGURATION
# ═══════════════════════════════════════════════════
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ═══════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ═══════════════════════════════════════════════════
# EMAIL CONFIGURATION
# Para Gmail: usar "App Password" (no password regular)
# https://support.google.com/accounts/answer/185833
# ═══════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Sistema StrateKaz <noreply@grasasyhuesos.com>
EMAIL_SUBJECT_PREFIX=[StrateKaz]

# ═══════════════════════════════════════════════════
# FRONTEND URL (para links en notificaciones por email)
# ═══════════════════════════════════════════════════
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════
# DOMINIO BASE DE LA PLATAFORMA (para subdominios de tenants)
# Ej: empresa.stratekaz.com — NO incluir protocolo ni subdominio
# ═══════════════════════════════════════════════════
PLATFORM_DOMAIN=stratekaz.com

# ═══════════════════════════════════════════════════
# PRECIOS Y CONFIGURACIONES DE NEGOCIO
# Configurados por el Gerente en la aplicación
# ═══════════════════════════════════════════════════
PRECIO_COMPRA_ECONORTE=3500
PRECIO_REFERENCIA_COMISION=3000
COMISION_FIJA_POR_KILO=100

# ═══════════════════════════════════════════════════
# SENTRY - Error Tracking (Opcional en desarrollo)
# ═══════════════════════════════════════════════════
# Obtener DSN en: https://sentry.io
# SENTRY_DSN=https://xxx@o123456.ingest.sentry.io/1234567
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# ═══════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════
DJANGO_LOG_LEVEL=DEBUG
DB_LOG_LEVEL=INFO
