# ═══════════════════════════════════════════════════
# CONFIGURACIÓN DE SEGURIDAD - EJEMPLO
# ═══════════════════════════════════════════════════
# Copiar este archivo a .env y configurar para producción

# ═══════════════════════════════════════════════════
# GENERAL
# ═══════════════════════════════════════════════════
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-in-production

# ═══════════════════════════════════════════════════
# HOSTS Y ORIGINS PERMITIDOS
# ═══════════════════════════════════════════════════
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com

# CORS - Solo dominios confiables
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# CSRF - Mismos dominios que CORS
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend URL para CSP
FRONTEND_URL=https://yourdomain.com

# ═══════════════════════════════════════════════════
# JWT TOKENS
# ═══════════════════════════════════════════════════
# Access token: 60 minutos (producción)
JWT_ACCESS_TOKEN_LIFETIME=60

# Refresh token: 24 horas (producción)
JWT_REFRESH_TOKEN_LIFETIME=1440

# ═══════════════════════════════════════════════════
# REDIS (para rate limiting y cache)
# ═══════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/2

# ═══════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════
DJANGO_LOG_LEVEL=WARNING
DB_LOG_LEVEL=WARNING

# ═══════════════════════════════════════════════════
# NOTAS DE SEGURIDAD
# ═══════════════════════════════════════════════════
# 1. NUNCA usar DEBUG=True en producción
# 2. Cambiar SECRET_KEY a un valor aleatorio único
# 3. Solo permitir hosts y origins necesarios
# 4. Configurar Redis con contraseña en producción
# 5. Revisar logs en backend/logs/security.log regularmente
