# ═══════════════════════════════════════════════════════════════════════════════
# TEMPLATE DE PRODUCCION - StrateKaz Multi-Instancia
# ═══════════════════════════════════════════════════════════════════════════════
#
# USO: Copiar este archivo y reemplazar los valores marcados con {PLACEHOLDER}
#
# COMANDO PARA GENERAR SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════
# IDENTIFICACION DE INSTANCIA
# ═══════════════════════════════════════════════════
# Nombre corto de la empresa (usado en logs y referencias)
INSTANCE_NAME={EMPRESA_SLUG}

# ═══════════════════════════════════════════════════
# DETECCION DE ENTORNO - CRITICO
# ═══════════════════════════════════════════════════
USE_CPANEL=True

# ═══════════════════════════════════════════════════
# DJANGO SETTINGS (P0-02, P0-06)
# ═══════════════════════════════════════════════════
# REQUERIDO: Generar clave unica de 64+ caracteres
SECRET_KEY={GENERAR_CON_SECRETS}

# OBLIGATORIO: False en produccion
DEBUG=False

# Dominio de la instancia
ALLOWED_HOSTS={SUBDOMINIO}.stratekaz.com

# ═══════════════════════════════════════════════════
# DATABASE (MySQL cPanel)
# ═══════════════════════════════════════════════════
# Formato cPanel: {cpanel_user}_{nombre}
DB_NAME={CPANEL_USER}_{EMPRESA_SLUG}_db
DB_USER={CPANEL_USER}_{EMPRESA_SLUG}_usr
DB_PASSWORD={PASSWORD_SEGURO_BD}
DB_HOST=localhost
DB_PORT=3306

# ═══════════════════════════════════════════════════
# JWT AUTHENTICATION
# ═══════════════════════════════════════════════════
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ═══════════════════════════════════════════════════
# CORS Y CSRF - SEGURIDAD
# ═══════════════════════════════════════════════════
CORS_ALLOWED_ORIGINS=https://{SUBDOMINIO}.stratekaz.com
CSRF_TRUSTED_ORIGINS=https://{SUBDOMINIO}.stratekaz.com

# ═══════════════════════════════════════════════════
# EMAIL (cPanel Mail o SMTP externo)
# ═══════════════════════════════════════════════════
EMAIL_HOST=mail.stratekaz.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@{SUBDOMINIO}.stratekaz.com
EMAIL_HOST_PASSWORD={PASSWORD_EMAIL}
DEFAULT_FROM_EMAIL=SGI StrateKaz <noreply@{SUBDOMINIO}.stratekaz.com>

# ═══════════════════════════════════════════════════
# FRONTEND URL (para links en emails)
# ═══════════════════════════════════════════════════
FRONTEND_URL=https://{SUBDOMINIO}.stratekaz.com

# ═══════════════════════════════════════════════════
# LOGGING (Produccion)
# ═══════════════════════════════════════════════════
DJANGO_LOG_LEVEL=WARNING
DB_LOG_LEVEL=WARNING

# ═══════════════════════════════════════════════════
# SENTRY (Opcional - Recomendado para produccion)
# ═══════════════════════════════════════════════════
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=production-{EMPRESA_SLUG}

# ═══════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════
RATELIMIT_ENABLE=True

# ═══════════════════════════════════════════════════
# CHECKLIST POST-CONFIGURACION
# ═══════════════════════════════════════════════════
# [ ] SECRET_KEY generada y unica
# [ ] DEBUG=False verificado
# [ ] Base de datos creada en cPanel
# [ ] Usuario BD con permisos
# [ ] Email configurado (o integrado via UI)
# [ ] SSL/HTTPS habilitado (cPanel AutoSSL)
# [ ] python manage.py migrate ejecutado
# [ ] python manage.py createsuperuser ejecutado
# [ ] Health check: curl https://{SUBDOMINIO}.stratekaz.com/api/health/
