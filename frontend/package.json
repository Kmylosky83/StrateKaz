{
  "name": "stratekaz-frontend",
  "private": true,
  "version": "5.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3010 --host",
    "build": "tsc && vite build",
    "build:validate": "npm run build && powershell -ExecutionPolicy Bypass -File build-validation.ps1",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 50"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/inter": "^5.0.0",
    "@fontsource/montserrat": "^5.2.8",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.1.0",
    "@hookform/resolvers": "^3.3.3",
    "@react-three/drei": "^9.117.0",
    "@react-three/fiber": "^8.17.10",
    "@sentry/react": "^10.39.0",
    "@tanstack/react-query": "^5.14.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-highlight": "^3.15.1",
    "@tiptap/extension-link": "^3.15.1",
    "@tiptap/extension-text-align": "^3.15.1",
    "@tiptap/extension-underline": "^3.15.1",
    "@tiptap/react": "^3.15.1",
    "@tiptap/starter-kit": "^3.15.1",
    "@types/three": "^0.170.0",
    "@xyflow/react": "^12.10.0",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "echarts-stat": "^1.2.0",
    "framer-motion": "^12.23.26",
    "html-to-image": "^1.11.13",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-gauge-chart": "^0.5.1",
    "react-hook-form": "^7.49.0",
    "react-router-dom": "^6.21.0",
    "react-signature-canvas": "^1.0.7",
    "react-to-print": "^3.2.0",
    "recharts": "^2.15.4",
    "simple-statistics": "^7.8.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0",
    "three": "^0.170.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.2",
    "@eslint/js": "^9.39.2",
    "@storybook/addon-a11y": "^8.5.0",
    "@storybook/addon-essentials": "^8.5.0",
    "@storybook/addon-interactions": "^8.5.0",
    "@storybook/addon-links": "^8.5.0",
    "@storybook/addon-onboarding": "^8.5.0",
    "@storybook/blocks": "^8.5.0",
    "@storybook/react": "^8.5.0",
    "@storybook/react-vite": "^8.5.0",
    "@storybook/test": "^8.5.0",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "^0.12.0",
    "globals": "^15.15.0",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "storybook": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.53.0",
    "vite": "^5.4.0",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.0.4"
  }
}
