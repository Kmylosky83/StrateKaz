# ================================================================
# Marketing Site .dockerignore
# Excludes files from Docker build context to optimize layer caching
# ================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
dist/
dist-ssr/
build/
.next/
out/

# Testing
coverage/
.nyc_output/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local

# Git
.git/
.gitignore

# Documentation
docs/
*.md
!README.md

# CI/CD
.github/

# Logs
logs/
*.log

# Temp files
*.tmp
*.bak
temp/
tmp/
.cache/
