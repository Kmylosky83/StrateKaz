# ========================================
# StrateKaz Marketing Site - EXAMPLE CONFIGURATION
# ========================================
# Copiar este archivo a .env.local para desarrollo local
# Copiar a .env.staging para staging
# Copiar a .env.production para producción

# ========================================
# API Configuration
# ========================================

# URL del backend API
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_BACKEND_URL=http://localhost:8000

# URL de la aplicación frontend
VITE_FRONTEND_APP_URL=http://localhost:3000

# ========================================
# App Configuration
# ========================================

VITE_APP_NAME=StrateKaz
VITE_APP_VERSION=1.0.5
VITE_APP_DESCRIPTION=Business Process Management Platform

# ========================================
# Environment
# ========================================

VITE_ENVIRONMENT=development

# ========================================
# Feature Flags
# ========================================

VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_CONTACT_FORM=true

# ========================================
# Analytics & Tracking (optional)
# ========================================

# Google Analytics
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Hotjar
# VITE_HOTJAR_ID=XXXXXXXX

# Google Tag Manager
# VITE_GTM_ID=GTM-XXXXXXX

# ========================================
# Social Media & Contact
# ========================================

VITE_LINKEDIN_URL=https://linkedin.com/company/stratekaz
VITE_TWITTER_URL=https://twitter.com/stratekaz
VITE_FACEBOOK_URL=https://facebook.com/stratekaz

VITE_CONTACT_EMAIL=contacto@stratekaz.com
VITE_SUPPORT_EMAIL=soporte@stratekaz.com

# ========================================
# Application URLs
# ========================================

VITE_APP_LOGIN_URL=http://localhost:3000/login
VITE_APP_DASHBOARD_URL=http://localhost:3000/dashboard
