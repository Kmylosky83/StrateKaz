{
  "name": "marketing_site",
  "version": "5.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development --port 3006",
    "dev:prod": "vite --mode production --port 3000",
    "build": "tsc && vite build --mode production && node scripts/post-build-cache-bust.js",
    "build:dev": "tsc && vite build --mode development && node scripts/post-build-cache-bust.js",
    "build:skip-ts": "vite build --mode production && node scripts/post-build-cache-bust.js",
    "build:dev-skip-ts": "vite build --mode development && node scripts/post-build-cache-bust.js",
    "preview": "vite preview --port 3000",
    "preview:dev": "vite preview --port 3001",
    "serve:prod": "npm run build && npm run preview",
    "serve:dev": "npm run build:dev && npm run preview:dev",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write . && eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist dev-dist node_modules/.vite coverage",
    "clean:install": "npm run clean && npm install",
    "icons:check": "node scripts/check-icons.js",
    "icons:generate": "node scripts/generate-icons.js",
    "build:deploy": "node scripts/build-production.js",
    "release": "node scripts/build-production.js"
  },
  "keywords": [
    "marketing",
    "sgi",
    "erp",
    "grc",
    "stratekaz",
    "react",
    "typescript"
  ],
  "author": "StrateKaz Team",
  "license": "MIT",
  "description": "Marketing site for StrateKaz — Consultoría 4.0 + Plataforma de Gestión 360°",
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "@sentry/react": "^10.21.0",
    "@types/three": "^0.181.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.18",
    "lucide-react": "^0.544.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.1",
    "tailwind-merge": "^2.3.0",
    "three": "^0.181.2",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@sentry/vite-plugin": "^4.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vite-pwa/assets-generator": "^1.0.1",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "terser": "^5.44.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^3.2.4"
  }
}
