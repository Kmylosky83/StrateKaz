{
  "$schema": "https://tr.designtokens.org/format/0.8/schema.json",
  "colors": {
    "black": {
      "deep": {
        "$type": "color",
        "$value": "#000000",
        "$description": "Fondo principal"
      },
      "card": {
        "$type": "color",
        "$value": "#0a0a0a",
        "$description": "Cards principales"
      },
      "card-soft": {
        "$type": "color",
        "$value": "#0f0f0f",
        "$description": "Cards secundarios, menos contraste"
      },
      "hover": {
        "$type": "color",
        "$value": "#1a1a1a",
        "$description": "Estados hover"
      },
      "hover-soft": {
        "$type": "color",
        "$value": "#151515",
        "$description": "Hover suave para elementos secundarios"
      },
      "border": {
        "$type": "color",
        "$value": "#2a2a2a",
        "$description": "Bordes principales"
      },
      "border-soft": {
        "$type": "color",
        "$value": "#1f1f1f",
        "$description": "Bordes sutiles"
      }
    },
    "white": {
      "text": {
        "$type": "color",
        "$value": "#ffffff",
        "$description": "Texto principal"
      },
      "text-soft": {
        "$type": "color",
        "$value": "#f8f8f8",
        "$description": "Texto principal suave"
      },
      "muted": {
        "$type": "color",
        "$value": "#e5e5e5",
        "$description": "Texto secundario"
      },
      "muted-soft": {
        "$type": "color",
        "$value": "#d0d0d0",
        "$description": "Texto terciario"
      },
      "subtle": {
        "$type": "color",
        "$value": "#b8b8b8",
        "$description": "Texto de menor importancia"
      }
    },
    "brand": {
      "50": { "$type": "color", "$value": "#fdf2f8" },
      "100": { "$type": "color", "$value": "#fce7f3" },
      "200": { "$type": "color", "$value": "#fbcfe8" },
      "300": { "$type": "color", "$value": "#f9a8d4" },
      "400": { "$type": "color", "$value": "#f472b6" },
      "500": {
        "$type": "color",
        "$value": "#ec268f",
        "$description": "Rosa StrateKaz principal - Solo CTAs y BPM"
      },
      "600": { "$type": "color", "$value": "#db2777" },
      "700": { "$type": "color", "$value": "#be185d" },
      "800": { "$type": "color", "$value": "#9d174d" },
      "900": { "$type": "color", "$value": "#831843" }
    },
    "system": {
      "blue": {
        "500": {
          "$type": "color",
          "$value": "#3b82f6",
          "$description": "ISO 9001 - Calidad"
        }
      },
      "green": {
        "500": {
          "$type": "color",
          "$value": "#22c55e",
          "$description": "ISO 14001 - Medio Ambiente"
        }
      },
      "red": {
        "500": {
          "$type": "color",
          "$value": "#ef4444",
          "$description": "ISO 45001 - Seguridad y Salud"
        }
      },
      "orange": {
        "500": {
          "$type": "color",
          "$value": "#f97316",
          "$description": "Innovación / PESV"
        }
      },
      "purple": {
        "500": {
          "$type": "color",
          "$value": "#a855f7",
          "$description": "Nuevos Desafíos / Coaching"
        }
      },
      "yellow": {
        "500": {
          "$type": "color",
          "$value": "#eab308",
          "$description": "SST / Gestión Ambiental"
        }
      }
    }
  },
  "spacing": {
    "section": {
      "xs": { "$type": "dimension", "$value": "2rem" },
      "sm": { "$type": "dimension", "$value": "3rem" },
      "md": { "$type": "dimension", "$value": "4rem" },
      "lg": { "$type": "dimension", "$value": "5rem" },
      "xl": { "$type": "dimension", "$value": "6rem" }
    },
    "card": {
      "sm": { "$type": "dimension", "$value": "1rem" },
      "md": { "$type": "dimension", "$value": "1.5rem" },
      "lg": { "$type": "dimension", "$value": "2rem" }
    },
    "container": {
      "sm": { "$type": "dimension", "$value": "1rem" },
      "md": { "$type": "dimension", "$value": "1.5rem" },
      "lg": { "$type": "dimension", "$value": "2rem" }
    }
  },
  "typography": {
    "fontFamilies": {
      "title": {
        "$type": "fontFamily",
        "$value": "Montserrat, sans-serif",
        "$description": "Títulos principales (h1-h3)"
      },
      "content": {
        "$type": "fontFamily",
        "$value": "Inter, sans-serif",
        "$description": "Texto body y contenido"
      }
    },
    "fontWeights": {
      "light": { "$type": "fontWeight", "$value": 300 },
      "normal": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 },
      "extrabold": { "$type": "fontWeight", "$value": 800 }
    },
    "fontSize": {
      "xs": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "base": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.125rem" },
      "xl": { "$type": "dimension", "$value": "1.25rem" },
      "2xl": { "$type": "dimension", "$value": "1.5rem" },
      "3xl": { "$type": "dimension", "$value": "1.875rem" },
      "4xl": { "$type": "dimension", "$value": "2.25rem" }
    }
  },
  "breakpoints": {
    "xs": { "$type": "dimension", "$value": "375px" },
    "sm": { "$type": "dimension", "$value": "640px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" },
    "2xl": { "$type": "dimension", "$value": "1536px" }
  },
  "shadows": {
    "soft": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.05)"
      }
    },
    "medium": {
      "$type": "shadow",
      "$value": {
        "offsetX": "0",
        "offsetY": "4px",
        "blur": "6px",
        "spread": "-1px",
        "color": "rgba(0, 0, 0, 0.1)"
      }
    }
  },
  "borderRadius": {
    "sm": { "$type": "dimension", "$value": "0.125rem" },
    "md": { "$type": "dimension", "$value": "0.375rem" },
    "lg": { "$type": "dimension", "$value": "0.5rem" },
    "xl": { "$type": "dimension", "$value": "0.75rem" },
    "2xl": { "$type": "dimension", "$value": "1rem" }
  }
}
