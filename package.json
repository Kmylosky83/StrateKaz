{
  "name": "stratekaz",
  "version": "5.2.0",
  "description": "StrateKaz - Sistema de Gestión Integral",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:frontend": "cd frontend && npm run lint",
    "format:frontend": "cd frontend && npm run format",
    "build": "cd frontend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "dev": "cd frontend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python manage.py runserver 0.0.0.0:8000",
    "db:migrate": "cd backend && python manage.py migrate",
    "db:make": "cd backend && python manage.py makemigrations"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "frontend/**/*.{css,json}": [
      "prettier --write"
    ]
  }
}
